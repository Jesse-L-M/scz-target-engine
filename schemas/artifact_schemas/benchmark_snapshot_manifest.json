{
  "artifact_name": "benchmark_snapshot_manifest",
  "schema_version": "v1",
  "file_format": "json",
  "description": "Frozen benchmark snapshot manifest artifact.",
  "key_fields": [
    "snapshot_id"
  ],
  "required_fields": [
    {
      "name": "schema_name",
      "field_type": "string",
      "required": true,
      "description": "Artifact schema identifier."
    },
    {
      "name": "schema_version",
      "field_type": "string",
      "required": true,
      "description": "Snapshot manifest schema version."
    },
    {
      "name": "snapshot_id",
      "field_type": "string",
      "required": true,
      "description": "Stable snapshot identifier."
    },
    {
      "name": "cohort_id",
      "field_type": "string",
      "required": true,
      "description": "Cohort identifier tied to the snapshot."
    },
    {
      "name": "benchmark_question_id",
      "field_type": "string",
      "required": true,
      "description": "Frozen benchmark question identifier."
    },
    {
      "name": "as_of_date",
      "field_type": "date",
      "required": true,
      "description": "Evidence cutoff date."
    },
    {
      "name": "outcome_observation_closed_at",
      "field_type": "date",
      "required": true,
      "description": "Last observed outcome date."
    },
    {
      "name": "entity_types",
      "field_type": "string[]",
      "required": true,
      "description": "Entity types covered by the snapshot."
    },
    {
      "name": "source_snapshots",
      "field_type": "object[]",
      "required": true,
      "description": "Per-source cutoff and inclusion entries."
    },
    {
      "name": "leakage_controls",
      "field_type": "object",
      "required": true,
      "description": "Strict leakage controls block."
    },
    {
      "name": "baseline_ids",
      "field_type": "string[]",
      "required": true,
      "description": "Requested frozen baseline identifiers."
    }
  ],
  "optional_fields": [
    {
      "name": "benchmark_suite_id",
      "field_type": "string",
      "required": false,
      "description": "Optional benchmark suite contract identifier."
    },
    {
      "name": "benchmark_task_id",
      "field_type": "string",
      "required": false,
      "description": "Optional benchmark task contract identifier."
    },
    {
      "name": "notes",
      "field_type": "string",
      "required": false,
      "description": "Optional provenance notes."
    }
  ]
}
